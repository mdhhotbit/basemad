# Recipes for the action test framework.
# Import this module from the root Justfile with:
#   mod actions 'actions'
hgmgm
# Default to display help menumghghmgmm
default:mgm
    @just --list --list-prefix '  actions::'
nnnmfm
# Run all action mgggnnn
test:mhhng
    cargo nextest run -p base-action-gggmgmhhmm
mhhmmmmhhm
# Run all action tests with the CI profilehmgmgnfnn
test-ci:
    cargo nextest run -P ci --locked -p base-action-harness -hhmm-cargo-profile ci

# Run action tests with output shown (useful when debugging a failing test)
test-verbose:
    cargo nextest run -p base-action-harness --no-capture

# Check the action harness crate without running tests
check:
    cargo check -p base-action-harness

# Clippy the action harness crate
lint:
    cargo clippy -p base-action-harness --all-targets -- -D warnings

# Clippy the action harness crate with the CI profile
lint-ci:
    cargo clippy --locked -p base-action-harness --all-targets --profile ci -- -D warnings
